{
  "name": "messenger-functions",
  "version": "1.0.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "build:zip": "npm run build && cd dist && zip -r function.zip . && mv function.zip ../dist/function.zip",
    "start": "FUNCTION_TARGET=handler functions-framework --target=handler",
    "test": "jest --runInBand",
    "lint": "eslint 'src/**/*.ts'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@google-cloud/firestore": "^7.11.0",
    "@google-cloud/secret-manager": "^5.6.0",
    "@google-cloud/functions-framework": "^3.4.5",
    "express": "^4.21.2",
    "firebase-admin": "^13.2.0",
    "jsonwebtoken": "^9.0.2",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^20.17.30",
    "@types/web-push": "^3.6.4",
    "@typescript-eslint/eslint-plugin": "^8.31.0",
    "@typescript-eslint/parser": "^8.31.0",
    "eslint": "^9.25.1",
    "jest": "^29.7.0",
    "supertest": "^7.1.0",
    "@types/supertest": "^6.0.3",
    "ts-jest": "^29.3.2",
    "typescript": "^5.8.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.ts"],
    "collectCoverageFrom": ["src/**/*.ts"]
  },
  "engines": {
    "node": ">=20"
  }
}
